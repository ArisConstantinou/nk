# Development defaults already use 127.0.0.1:5192.
NODE_ENV=production
ADMIN_API_HOST=127.0.0.1
ADMIN_API_PORT=5192
ADMIN_DB_PATH=.data/admin.sqlite
ADMIN_MEDIA_PATH=.data/media
ADMIN_SESSION_HOURS=8
ADMIN_ALLOWED_ORIGINS=http://127.0.0.1:5191
ADMIN_ALLOW_LOOPBACK_SETUP=false
# Enable only when a loopback reverse proxy overwrites X-Forwarded-For.
ADMIN_TRUST_LOOPBACK_PROXY=false

# Required before the first owner in every start mode except npm run dev:admin.
# Generate a unique high-entropy value and never commit the real value.
ADMIN_BOOTSTRAP_TOKEN=replace-with-a-long-random-server-secret

# Enable when the Node service should serve the built Vite site and API together.
ADMIN_SERVE_SITE=false
