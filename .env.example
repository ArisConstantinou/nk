# Development defaults already use 127.0.0.1:5192.
NODE_ENV=production
ADMIN_API_HOST=127.0.0.1
ADMIN_API_PORT=5192
ADMIN_DB_PATH=.data/admin.sqlite
ADMIN_MEDIA_PATH=.data/media
ADMIN_SESSION_HOURS=8
ADMIN_ALLOWED_ORIGINS=http://127.0.0.1:5191
ADMIN_ALLOW_LOOPBACK_SETUP=false
# Enable only when a loopback reverse proxy overwrites X-Forwarded-For.
ADMIN_TRUST_LOOPBACK_PROXY=false

# Required before the first owner in every start mode except npm run dev:admin.
# Generate a unique high-entropy value and never commit the real value.
ADMIN_BOOTSTRAP_TOKEN=replace-with-a-long-random-server-secret

# Enable when the Node service should serve the built Vite site and API together.
ADMIN_SERVE_SITE=false

# Public Firebase web configuration used by GitHub Pages and optional localhost sign-in.
# Firebase web API keys identify a project; Firebase Auth and rules enforce access.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_ADMIN_EMAILS=
VITE_FIREBASE_EMAIL_PASSWORD_ENABLED=false

# The local Node API verifies Firebase ID tokens before issuing its normal secure session.
# These may match the public VITE values above. The local administrator must already exist
# in SQLite with the same email; Firebase never creates or elevates a local account.
FIREBASE_API_KEY=
FIREBASE_ADMIN_EMAILS=
# Interactive experience modules are opt-in and independently deployable.
# Set false to remove the module without changing the page renderer.
VITE_EXPERIENCE_ELECTRICAL_INSTALLATIONS=true

# Request-a-quote location search currently uses the public Photon demo endpoint
# with a Nicosia-only bounding box. For higher-volume production traffic, point
# the frontend at a privately hosted Photon-compatible service.
VITE_PHOTON_ENDPOINT=https://photon.komoot.io/api/
