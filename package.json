{
  "name": "nk-electrical-experience",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5191 --strictPort",
    "dev:admin-api": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --watch server/admin-server.mjs",
    "dev:admin": "node server/run-admin-dev.mjs",
    "start:admin": "node server/admin-server.mjs",
    "admin:create-owner": "node server/create-owner.mjs",
    "build": "tsc -b && vite build",
    "build:pages": "tsc -b && vite build --mode github-pages",
    "check:admin": "npm run test:admin-api && npm run build",
    "preview": "vite preview --host 127.0.0.1 --port 5191 --strictPort",
    "test": "npm run test:admin-api",
    "test:admin-api": "node --test server/tests/*.test.mjs"
  },
  "dependencies": {
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/manrope": "^5.2.8",
    "@remotion/player": "^4.0.357",
    "firebase": "^12.16.0",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "remotion": "^4.0.357",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "~5.7.2",
    "vite": "^6.0.5"
  }
}
